# Copy selected values into .env or export them in your shell.
# Do not commit real API keys or production DSNs.

# Application and logging
AGENT_APP_NAME=agents
AGENT_DEBUG=false

# OpenAI-compatible Chat Completions provider.
# The runtime keeps using /v1/chat/completions, not the Responses API.
AGENT_MODEL=openai:gpt-4.1
AGENT_OPENAI_API_KEY=
AGENT_OPENAI_BASE_URL=https://api.openai.com/v1

# Optional alternate model referenced by example/agents.full.yaml.
AGENT_FAST_MODEL=openai:gpt-4.1-mini

# User and session isolation.
AGENT_DEFAULT_USER_ID=default
AGENT_SESSIONS_DIR=./data/sessions

# SQLite storage, enabled by default.
AGENT_STORAGE_BACKEND=sqlite
AGENT_DB_PATH=./data/agent.sqlite3

# PostgreSQL storage alternative.
# To use it, install the postgres extra and set:
#   AGENT_STORAGE_BACKEND=postgres
#   AGENT_POSTGRES_DSN=postgresql://user:password@localhost:5432/agents
AGENT_POSTGRES_DSN=

# API server defaults.
AGENT_API_HOST=127.0.0.1
AGENT_API_PORT=8000
AGENT_API_RELOAD=false

# CORS. Leave AGENT_CORS_ORIGINS empty to disable CORS middleware.
AGENT_CORS_ORIGINS=
AGENT_CORS_ALLOW_CREDENTIALS=false
AGENT_CORS_ALLOW_METHODS=*
AGENT_CORS_ALLOW_HEADERS=*

# Custom variables collected by Settings.effective_custom_env.
# These are available for future custom Agent/Tool integrations.
AGENT_CUSTOM_ENV_PREFIXES=AGENT_CUSTOM_,AGENT_AGENT_,AGENT_TOOL_
AGENT_CUSTOM_EXAMPLE=demo
AGENT_AGENT_PROFILE=research
AGENT_TOOL_SEARCH_TIMEOUT=15
